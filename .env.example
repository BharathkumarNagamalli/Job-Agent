# ============================================
# Job Agent - Environment Variables
# ============================================
# Copy this to .env and fill in your keys

# Flask secret key (change this!)
SECRET_KEY=your-secret-key-here

# ============================================
# REQUIRED: JSearch API (for job search)
# ============================================
# 1. Go to: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# 2. Sign up for free (500 requests/month on free tier)
# 3. Click "Subscribe to Test" → select FREE plan
# 4. Copy your API key from the "Header Parameters" section
JSEARCH_API_KEY=your_rapidapi_key_here

# ============================================
# REQUIRED: Gemini API (for AI features)
# ============================================
# 1. Go to: https://aistudio.google.com/app/apikey
# 2. Click "Create API Key"
# 3. Copy and paste below
GEMINI_API_KEY=your_gemini_api_key_here
